# OctoberCMS environment variables
# Copy to .env for local development.
# For production, set secrets in .kamal/secrets.

APP_KEY=base64:              # openssl rand -base64 32, prefix with "base64:"
APP_URL=https://<%= domain %>
APP_ENV=production
APP_DEBUG=false
APP_NAME=OctoberCMS
APP_LOCALE=en

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=<%= db_name %>
DB_USERNAME=<%= db_username %>
DB_PASSWORD=

STORAGE_DRIVER=local
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

LOG_CHANNEL=stderr
LOG_LEVEL=error

MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@<%= domain %>
MAIL_FROM_NAME=OctoberCMS
